// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
}

enum VoteType {
  UP
  DOWN
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String         @id @default(cuid())
  name              String?
  email             String?        @unique
  emailVerified     DateTime?
  createdSubreddits       Subreddit[]          @relation("CreatedBy")
  subscriptions           Subscription[]
  votes                   Vote[]
  notifications           Notification[]       @relation("NotificationFrom")
  receivedNotifications   Notification[]

  username         String?       @unique
  resetToken       String?       @db.Text
  resetTokenExpiry DateTime?

  image       String?
  passwordHash String? // bcrypt hash for credentials login
  isAI        Boolean  @default(false)
  aiRole      String?  // "Newton" | "Midas" | "Flora"
  isAdmin     Boolean  @default(false)
  reputation  Int       @default(0)
  level       Int       @default(1)
  createdAt   DateTime  @default(now())
  accounts    Account[]
  sessions    Session[]
  Post        Post[]
  Comment     Comment[]
  CommentVote CommentVote[]
  Bookmark    Bookmark[]
  reports     Report[]       @relation("Reporter")
  resolved    Report[]       @relation("Resolver")
}

model Subreddit {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String?   // 中文显示名（如 "SAT/ACT 备考"），保留 name 用于 URL slug
  category    String?   // "exams" | "applications" | "insights" | "visa" | "career"
  description String?   @db.Text
  sortOrder   Int      @default(0)
  isOfficial  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]

  creatorId   String?
  Creator     User?          @relation("CreatedBy", fields: [creatorId], references: [id])
  subscribers Subscription[]

  @@index([name])
}

model Subscription {
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  subreddit   Subreddit @relation(fields: [subredditId], references: [id])
  subredditId String

  @@id([userId, subredditId])
}

model Post {
  id          String     @id @default(cuid())
  title       String
  content     Json?
  embedding   Json?
  status      PostStatus @default(PUBLISHED)
  isPinned    Boolean    @default(false)
  pinnedAt    DateTime?
  isFeatured  Boolean    @default(false)
  featuredAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  voteCount   Int        @default(0)
  hotScore    Float?
  author      User      @relation(fields: [authorId], references: [id])
  authorId    String
  subreddit   Subreddit @relation(fields: [subredditId], references: [id])
  subredditId String
  comments    Comment[]
  votes       Vote[]
  bookmarks   Bookmark[]
  tags        PostTag[]
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String

  replyToId String?
  replyTo   Comment?  @relation("ReplyTo", fields: [replyToId], references: [id], onDelete: SetNull, onUpdate: SetNull)
  replies   Comment[] @relation("ReplyTo")

  votes     CommentVote[]
  commentId String?
}

model Vote {
  user   User     @relation(fields: [userId], references: [id])
  userId String
  post   Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  type   VoteType

  @@id([userId, postId])
}

model CommentVote {
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String
  type      VoteType

  @@id([userId, commentId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "COMMENT_REPLY"
  fromUserId  String
  postId      String?
  commentId   String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromUser    User     @relation("NotificationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Bookmark {
  userId    String
  postId    String

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
}

model Report {
  id           String    @id @default(cuid())
  reporterId   String
  targetType   String    // "post" | "comment"
  targetId     String
  reason       String    // "spam"|"harassment"|"inappropriate"|"misinformation"|"other"
  description  String?   @db.Text
  status       String    @default("pending") // "pending"|"resolved"|"dismissed"
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedById String?

  reporter     User      @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy   User?     @relation("Resolver", fields: [resolvedById], references: [id])

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)
  confirmed    Boolean  @default(false)
  confirmToken String?
}

model IntelSource {
  id                  String    @id @default(cuid())
  label               String
  url                 String
  type                String    @default("webpage") // "rss" | "webpage"
  category            String?   // "admissions" | "exams" | "rankings" | "general"
  priority            String    @default("medium")  // "high" | "medium" | "low"
  crawlInterval       Int       @default(30)        // 分钟
  isActive            Boolean   @default(true)
  contentSelector     String?   // CSS 选择器
  consecutiveFailures Int       @default(0)
  maxFailures         Int       @default(5)
  lastCrawlAt         DateTime?
  lastError           String?
  crawlCount          Int       @default(0)
  articleCount        Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  crawlLogs CrawlLog[]
}

model CrawlLog {
  id            String      @id @default(cuid())
  source        IntelSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId      String
  status        String      // "success" | "failed" | "deduplicated"
  url           String?
  title         String?
  contentHash   String?
  contentLength Int?
  errorMessage  String?
  postId        String?
  duration      Int?
  createdAt     DateTime    @default(now())

  @@index([sourceId, createdAt])
}

model PipelineConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON
  updatedAt DateTime @updatedAt
}

model PipelineExecution {
  id            String    @id @default(cuid())
  pipelineType  String
  status        String    @default("pending")
  entityId      String?
  inputSummary  String?
  outputSummary String?
  errorMessage  String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  durationMs    Int?
  retryCount    Int       @default(0)
  maxRetries    Int       @default(3)
  createdAt     DateTime  @default(now())

  @@index([pipelineType, status, createdAt], name: "idx_pipeline_exec_type_status")
  @@index([entityId], name: "idx_pipeline_exec_entity")
}

model EmbeddingJob {
  id            String    @id @default(cuid())
  postId        String    @unique
  status        String    @default("pending")
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  errorMessage  String?
  dimensions    Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, createdAt], name: "idx_embedding_job_status")
  @@index([postId], name: "idx_embedding_job_post")
}

model PostFeedback {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  rating    String   // 'helpful' | 'not_helpful'
  reason    String?
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PromptVersion {
  id          String   @id @default(cuid())
  agentRole   String
  promptName  String
  version     Int      @default(1)
  content     String
  changeNotes String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([agentRole])
  @@index([isActive])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  category  String?
  postCount Int      @default(0)
  createdAt DateTime @default(now())
  posts     PostTag[]

  @@index([category])
}

model PostTag {
  id        String   @id @default(cuid())
  postId    String
  tagId     String
  createdAt DateTime @default(now())
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
}
