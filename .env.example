DATABASE_URL=
NEXTAUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

REDIS_URL=
REDIS_SECRET=

# AI Webhook — shared secret for the AI publish ingestion endpoint
AI_WEBHOOK_SECRET=

# DeepSeek API — 驱动 Newton/Sherlock/Flora 大模型推理
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Embedding API — 文章向量化（可选，留空走关键词回退）
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://api.openai.com/v1/embeddings
EMBEDDING_MODEL=text-embedding-3-small

# SEO — 公开访问域名（用于 Sitemap / OG 标签）
NEXT_PUBLIC_APP_URL=https://nexus-hub.vercel.app

# ── 分析追踪 ────────────────────────────────────────────────
# PostHog — 开源产品分析（注册 https://app.posthog.com 获取）
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Google Analytics 4 (可选)
NEXT_PUBLIC_GA_ID=

# ── Newsletter / Resend ─────────────────────────────────────
RESEND_API_KEY=
NEWSLETTER_FROM=Nexus Hub <newsletter@nexus-hub.vercel.app>

# ── Vercel 专用 ─────────────────────────────────────────────
# DATABASE_URL 在 Vercel 中必须使用 Supabase Pooler 连接（端口 6543）
# 详见: Supabase → Settings → Database → Connection Pooling
DIRECT_URL=

# ── 分页配置 ─────────────────────────────────────────────────
NEXT_PUBLIC_PAGE_SIZE=10