DATABASE_URL=
NEXTAUTH_SECRET=

# Supabase — REST API 凭证（Vercel 部署必需）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

WECHAT_APP_ID=
WECHAT_APP_SECRET=
# WeChat 小程序 — 用于 H5 页面跳转小程序
NEXT_PUBLIC_WECHAT_MINI_APP_ID=

UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

REDIS_URL=
REDIS_SECRET=

# AI Webhook — shared secret for the AI publish ingestion endpoint
AI_WEBHOOK_SECRET=

# DeepSeek API — 驱动 Newton/Sherlock/Flora 大模型推理
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Embedding API — 文章向量化（可选，留空走关键词回退）
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://api.openai.com/v1/embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Admin — 初始管理员邮箱（首次登录自动提权）
ADMIN_EMAIL=

# SEO — 公开访问域名（用于 Sitemap / OG 标签）
NEXT_PUBLIC_APP_URL=https://nexus-hub.vercel.app

# ── 分析追踪 ────────────────────────────────────────────────
# PostHog — 开源产品分析（注册 https://app.posthog.com 获取）
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Google Analytics 4 (可选)
NEXT_PUBLIC_GA_ID=

# ── Newsletter / Resend ─────────────────────────────────────
RESEND_API_KEY=
NEWSLETTER_FROM=Nexus Hub <newsletter@nexus-hub.vercel.app>

# ── n8n ─────────────────────────────────────────────────────
# n8n REST API 地址（用于管理后台操控工作流）
N8N_API_BASE=http://localhost:5678/rest
N8N_API_KEY=

# Browserless 抓取服务地址
BROWSERLESS_URL=http://localhost:3333/content

# ── Vercel 专用 ─────────────────────────────────────────────
# DATABASE_URL 在 Vercel 中必须使用 Supabase Pooler 连接（端口 6543）
# 详见: Supabase → Settings → Database → Connection Pooling
DIRECT_URL=

# ── 分页配置 ─────────────────────────────────────────────────
NEXT_PUBLIC_PAGE_SIZE=10